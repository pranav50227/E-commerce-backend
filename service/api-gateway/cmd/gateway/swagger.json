          },
          "404": {
            "description": "Product not found"
          }
        }
      },
      "put": {
        "summary": "Update product details",
        "tags": ["Products"],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
